# Deep Counsel AI Chat Environment Variables

# AI Provider Configuration (Optional - for real AI integration)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (Optional - for persistent chat history)
# DATABASE_URL=your_database_url_here

# Authentication (Optional - for user management)
# NEXTAUTH_SECRET=your_nextauth_secret_here
# NEXTAUTH_URL=http://localhost:3000

# For development, the app works without these credentials
# It uses simulated responses to demonstrate functionality
NODE_ENV=development